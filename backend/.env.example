PORT=3000

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Single admin account (generate hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))")
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_ROLE=ADMIN

# SMTP configuration (read-only via API, used to send campaign emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_SENDER_NAME=
SMTP_SENDER_EMAIL=
